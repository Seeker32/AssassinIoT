# Bento Pipeline Configuration
# Copy to .env and adjust values for your environment

# MQTT Broker connection (EMQX or compatible)
# Format: tcp://host:port  or  tls://host:port
MQTT_URL=tcp://emqx:1883

# TimescaleDB / PostgreSQL connection (used by all sql_* outputs)
# Format: postgres://user:password@host:port/database?options
POSTGRES_DSN=postgres://postgres:password@database:5432/postgres?sslmode=disable

# Log level: TRACE | DEBUG | INFO | WARN | ERROR | FATAL
BENTO_LOG_LEVEL=INFO
